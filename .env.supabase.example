# Copy to .env.supabase.local and fill these in.

# Supabase project.
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Optional. Use this instead of running `npx supabase login`.
# SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_ACCESS_TOKEN

# Optional. Defaults to https://<project-ref>.supabase.co
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Turnstile keys. Site key goes to the Vite frontend. Secret key goes to Supabase Functions.
VITE_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# Optional frontend origins used by Edge Function CORS. Comma-separate local and deployed origins.
PUBLIC_APP_ORIGIN=http://localhost:4173,http://127.0.0.1:4173

# Optional. Leave blank and scripts/wire-supabase.ps1 will generate these once.
VISITOR_SIGNING_SECRET=
VISITOR_HASH_SALT=
ABUSE_HASH_SALT=
ADMIN_API_TOKEN=
RAW_EVENT_RETENTION_DAYS=7
