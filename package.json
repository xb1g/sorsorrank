{
  "name": "sorsorrank-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "backend:check": "tsc -p tsconfig.backend.json --noEmit",
    "test:backend": "node --test --import tsx backend/core/__tests__/*.test.ts",
    "supabase:wire": "powershell -ExecutionPolicy Bypass -File scripts/wire-supabase.ps1",
    "supabase:wire:dry": "powershell -ExecutionPolicy Bypass -File scripts/wire-supabase.ps1 -SkipLink -SkipDbPush -SkipFunctions -SkipSecrets",
    "supabase:import-members": "powershell -ExecutionPolicy Bypass -File scripts/import-members-csv.ps1",
    "supabase:import-politigraph": "node scripts/import-politigraph-members.mjs",
    "supabase:import-featured": "powershell -ExecutionPolicy Bypass -File scripts/import-featured-politicians.ps1",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "html2canvas": "^1.4.1",
    "preact": "^10.26.9"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
